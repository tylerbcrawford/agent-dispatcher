# Agent limits
AC_MAX_AGENTS=3
AC_CPU_THRESHOLD=80
AC_RAM_THRESHOLD=85
AC_STALL_THRESHOLD_MIN=5
AC_MAX_BUDGET_USD=2          # Per-agent USD budget cap
AC_LOG_RETENTION_DAYS=30

# Discord (optional)
AC_DISCORD_CHANNEL=
AC_DISCORD_TOKEN=

# Paths
AC_VAULT_PATH=/path/to/your/todo/directory
AC_PROJECTS_PATH=./projects.json
AC_PERMISSIONS_DIR=./permissions
AC_PROMPTS_DIR=./prompts
AC_SESSIONS_DIR=./sessions
# Runner + web container share this socket. For local dev without systemd: mkdir -p /run/agent-dispatcher (or set this to /tmp/agent-dispatcher.sock).
AC_UNIX_SOCKET=/run/agent-dispatcher/dispatcher.sock

# Ports
AC_WEB_PORT=3100
AC_SERVER_PORT=3101

# Git
AC_DEFAULT_GIT_BRANCH=true

# Providers
AC_GEMINI_BINARY=gemini
AC_CODEX_BINARY=codex
GEMINI_API_KEY=
# Codex auth: uses system keyring, NOT env var.
# Run: echo "$OPENAI_API_KEY" | codex login --with-api-key
