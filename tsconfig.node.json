{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true
  },
  "include": ["src/server/**/*", "src/runner/**/*", "src/shared/**/*"],
  "exclude": ["src/**/__tests__/**", "src/**/*.test.ts"]
}
