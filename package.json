{
  "name": "agent-dispatcher",
  "version": "0.2.0",
  "private": true,
  "description": "Web dashboard for orchestrating headless AI coding agents (Claude Code, Gemini CLI, Codex CLI) — a markdown-driven task board with live xterm.js terminals, a human-in-the-loop work queue, and a composable prompt library.",
  "keywords": ["ai-agents", "claude", "claude-code", "gemini", "codex", "agent-orchestration", "developer-tools", "react", "typescript"],
  "license": "MIT",
  "author": "Tyler Crawford",
  "repository": { "type": "git", "url": "https://github.com/tylerbcrawford/agent-dispatcher.git" },
  "homepage": "https://github.com/tylerbcrawford/agent-dispatcher#readme",
  "bugs": { "url": "https://github.com/tylerbcrawford/agent-dispatcher/issues" },
  "engines": { "node": ">=20" },
  "type": "module",
  "scripts": {
    "dev:web": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:runner": "tsx watch src/runner/index.ts",
    "build": "vite build && tsc -p tsconfig.node.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "deploy": "./deploy.sh",
    "deploy:runner": "./deploy.sh runner",
    "deploy:frontend": "./deploy.sh frontend",
    "deploy:all": "./deploy.sh all"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "ws": "^8.19.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "happy-dom": "^20.7.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
